{
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/ops/stream/route.ts": {
      "maxDuration": 250
    },
    "src/app/api/sentinel/heartbeat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ops/health/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ops/health/alert/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/scadenze/notify",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/impresa/report-compliance?cron=1",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/health/voice",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sentinel/heartbeat",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/ops/health/alert",
      "schedule": "*/2 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/studio",
      "destination": "https://normaai-studio.vercel.app"
    },
    {
      "source": "/studio/:path*",
      "destination": "https://normaai-studio.vercel.app/:path*"
    }
  ]
}
